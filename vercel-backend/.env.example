# Your real Groq API key (console.groq.com/keys). Only lives on the server.
GROQ_API_KEY=

# A secret you make up (e.g. `openssl rand -hex 32`). This is what the
# Clonosaur app sends instead of a real Groq key — set it here and again as
# the "API key" field in the app's hybrid-mode provider config.
CLONOSAUR_SHARED_SECRET=
